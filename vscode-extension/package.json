{
  "name": "reposage-vscode",
  "displayName": "RepoSage",
  "description": "AI-powered code review assistant for VS Code",
  "version": "0.1.0",
  "publisher": "reposage",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onCommand:reposage.reviewCurrentFile",
    "onCommand:reposage.configureApiKey",
    "onView:reposage.sidebarView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reposage.reviewCurrentFile",
        "title": "RepoSage: Review Current File"
      },
      {
        "command": "reposage.configureApiKey",
        "title": "RepoSage: Configure API Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reposage-sidebar",
          "title": "RepoSage",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "reposage-sidebar": [
        {
          "type": "webview",
          "id": "reposage.sidebarView",
          "name": "Review Results"
        }
      ]
    },
    "configuration": {
      "title": "RepoSage",
      "properties": {
        "reposage.apiUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "RepoSage backend API base URL"
        },
        "reposage.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for RepoSage backend authentication",
          "editPresentation": "singleline",
          "order": 1
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "typescript": "^5.3.3"
  }
}
